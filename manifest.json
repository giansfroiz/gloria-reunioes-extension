{
  "manifest_version": 3,
  "name": "Gloria Reuniões – Transcrição",
  "version": "1.0.0",
  "description": "Transcreve reuniões do Google Meet, Zoom e Teams com identificação de falantes, salvando no Supabase.",
  "permissions": [
    "tabCapture",
    "scripting",
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "*://meet.google.com/*",
    "*://*.zoom.us/*",
    "*://teams.microsoft.com/*",
    "*://vwxuqljtqqmevgiwecsf.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gloria Reuniões",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "128": "icons/icon128.png"
  }
}
